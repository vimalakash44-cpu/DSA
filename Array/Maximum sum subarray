class Solution {
    public int maxSubArray(int[] nums) {
        int max=nums[0];
        int sum=0;
        int l=0;
        for(int i=0;i<nums.length;i++){
            sum=sum+nums[i];
            if(sum<0){
                max=Math.max(max,sum);
                sum=0;
            }
            else{
                max=Math.max(max,sum);
            }
        }
    return max;
    }
}
