class Solution {
    public boolean canSortArray(int[] nums) {
        int prevmax = Integer.MIN_VALUE;
        int i=0;
        int currentmin=0;
        int currentmax=0;
        while(i<nums.length){
            int bits=Integer.bitCount(nums[i]);
            currentmin=nums[i];
            currentmax=nums[i];
            while(i<nums.length){
                if(Integer.bitCount(nums[i])!=bits){
                    break;
                }
                currentmin=Math.min(currentmin,nums[i]);
                currentmax=Math.max(currentmax,nums[i]);
                i++;
            }
            if(currentmin<prevmax){
                return false;
            }
            prevmax=currentmax;
        }
        return true;
    }
}
