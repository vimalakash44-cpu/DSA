class Solution {
    public int numberOfChild(int n, int k) {
        int[] arr;
        arr=new int[n];
        for(int i=0;i<n;i++){
            arr[i]=i;
        }
        int s=k%(2*(n-1));
        if(s<n-1){
            return s;
        }
        else{
            return (2*(n-1))-s;
        }
    }
}
