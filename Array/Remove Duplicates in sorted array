class Solution {
    public int removeDuplicates(int[] nums) {
        int l=0;
        int r=1;
        for(int i=0;i<nums.length;i++){
            if(r<nums.length){
                if(nums[l]==nums[r]){
                    r=r+1;
                }
                else if(nums[l]!=nums[r]){
                    l=l+1;
                    nums[l]=nums[r];
                    r=r+1;
                }
            }
       }
       return l+1;
    }
}}
