class Solution {
    public int canCompleteCircuit(int[] gas, int[] cost) {
      int tank=0;
      int s=0;
      int total=0;
      for(int i=0;i<gas.length;i++){
        int diff=gas[i]-cost[i];
        tank+=diff;
        total+=diff;
        if(tank<0){
            tank=0;
            s=i+1;
        }
      }
      if(total<0){
        return -1;
      }
      else{
        return s;
      }
    }
}
