bool hasAlternatingBits(int n) {
    int i=0;
    int num=0;
    while(n>0){
        if(i==0){
            num=n%2;
            n=n/2;
            i++;
        }
        else{
            if(n%2 !=num){
                num=n%2;
                n=n/2;
            }
            else{
                return false;
            }
        }
    }
    return true;
}
